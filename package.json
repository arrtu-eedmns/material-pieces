{
  "name": "material-pieces",
  "version": "1.0.0",
  "description": "Pieces — sistema de componentes CSS/JS baseado em HSL tokens e Material Design 3",
  "style": "css/pieces.css",
  "files": [
    "css/",
    "js/"
  ],
  "exports": {
    ".":                  "./css/pieces.css",
    "./md3":              "./css/pieces.md3.css",
    "./notion":           "./css/pieces.notion.css",
